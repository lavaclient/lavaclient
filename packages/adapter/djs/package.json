{
    "name": "@lavaclient/adapter-djs",
    "version": "1.0.0-rc.1",
    "description": "Integrates Discord.js into Lavaclient.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "maintainers": [
        {
            "email": "hi@vzt.gay",
            "name": "vzt",
            "url": "https://vzt.gay"
        }
    ],
    "files": [
        "dist/*",
        "!dist/.tsbuildinfo"
    ],
    "scripts": {
        "build": "tsc",
        "check": "tsc --noEmit",
        "format": "prettier -w src/*",
        "prepublishOnly": "pnpm run format && pnpm run build"
    },
    "devDependencies": {
        "@lavaclient/config-prettier": "workspace:^",
        "@lavaclient/config-typescript": "workspace:^",
        "@types/node": "catalog:",
        "@types/ws": "catalog:",
        "typed-emitter": "catalog:",
        "typescript": "catalog:"
    },
    "dependencies": {
        "tslib": "catalog:"
    },
    "engines": {
        "node": ">=20"
    }
}
